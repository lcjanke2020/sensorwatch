# Runtime output
logs/

# Python
__pycache__/
*.pyc
.venv/
dist/
build/
*.egg-info/

# cffi-generated extension build artifacts (sensorwatch/_sw_cffi.*)
/sensorwatch/_sw_cffi.c
/sensorwatch/*.pyd
/sensorwatch/*.so
*.o
*.obj
*.lib
*.exp
# MSVC in-place build intermediates and cibuildwheel output
/Release/
wheelhouse/

# Rust (cargo build output). Cargo.lock IS committed for reproducible CI builds.
/rust/target/

# Tooling / editor. All of .claude/ stays local: this is a public repo, so a
# committed settings.json would override the model choice of anyone who clones it.
# The local model pin is a symlink into the private settings share (LEO-345).
.claude/
*.un~
*~

# Agent session working files (LEO-345 flow: bookend/handoff artifacts, never committed)
PLAN.md
TICKET.md
FINDINGS.md
COST.md
