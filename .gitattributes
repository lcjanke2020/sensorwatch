# Keep the checked-in bindgen output line-ending-stable so the CI bindgen-drift
# diff is deterministic across Windows and Linux runners (whose git autocrlf
# defaults differ, and where bindgen may emit CRLF vs LF). git normalizes this
# file to LF for storage and comparison on every platform.
/rust/sensorwatch-sys/src/bindings.rs text eol=lf

# Shell scripts must stay LF to run under bash (including Git Bash on Windows).
*.sh text eol=lf

# The vendored C core (a verbatim mirror of src/ + include/, published inside the
# sensorwatch-sys crate) is pinned to LF so the CI `vendor-sync` diff is deterministic
# across Windows and Linux runners regardless of a contributor's autocrlf setting —
# same rationale as the bindings.rs rule above. The canonical sources are already LF.
/rust/sensorwatch-sys/vendor/** text eol=lf

# The golden logger fixture is byte-compared (include_bytes!) against LogWriter
# output in the CLI's tests; an autocrlf checkout on the Windows runner would
# rewrite it to CRLF and break the comparison. Generated with LF by
# tests/golden/generate_fixture.py — keep it that way on every platform.
/rust/sensorwatch-cli/tests/golden/** text eol=lf
